<div class="container" style="max-width: 600px; margin: 40px auto; font-family: sans-serif;">
  <header style="text-align: center; margin-bottom: 30px;">
    <h1>Freelancer Billing Dashboard</h1>
    <p class="text-muted">Use the button below to execute design patterns and view server logs.</p>
  </header>

  <% if notice %>
    <div style="background-color: #d4edda; color: #155724; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
      <%= notice %>
    </div>
  <% end %>

  <div style="text-align: center;">
    <%= button_to "Run Check & View Server Log", dashboard_check_path, method: :get, style: "
      background-color: #007bff; 
      color: white; 
      border: none; 
      padding: 14px 28px; 
      font-size: 16px; 
      border-radius: 6px; 
      cursor: pointer; 
      box-shadow: 0 2px 5px rgba(0,0,0,0.1); 
      transition: background-color 0.2s;" %>
  </div>
</div>